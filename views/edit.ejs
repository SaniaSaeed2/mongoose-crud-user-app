<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

</head>
<body>

    <div class="w-full h-full bg-zinc-900 p-10 text-white">
        <div class="nav mb-10">
            <a class="text-blue-500" href="/read">Read Users</a>
        </div>
        <h1 class="text-3xl tracking-tighter mb-3">Update User</h1>

        <form action="/update/<%= users._id%>" method="post">
            <input type="text" name="name" placeholder="Name"
                class="px-5 py-2 bg-transparent border-2 border-zinc-800 rounded-lg outline-none" value="<%= users.name%>">
            <input type="text" name="email" placeholder="Email"
                class="px-5 py-2 bg-transparent border-2 border-zinc-800 rounded-lg outline-none" value="<%= users.email%>">
            <input type="text" name="image" placeholder="Image"
                class="px-5 py-2 bg-transparent border-2 border-zinc-800 rounded-lg outline-none" value="<%= users.image%>">
            <input type="submit" value="Update User" class="px-5 py-2 bg-yellow-500 rounded-lg ml-3 text-black">


        </form>
    </div>

</body>
</html>